# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com/v2/ -> Connect -> Connection String
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/teslainvest?retryWrites=true&w=majority

# JWT Secret (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin Credentials (can be set via environment)
ADMIN_EMAIL=admin@tesla.com
ADMIN_PASSWORD=admin123
