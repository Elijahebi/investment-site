{
  "version": 2,
  "buildCommand": "npm install && cd backend && npm install",
  "outputDirectory": "pages",
  "functions": {
    "backend/api/index.js": {
      "maxDuration": 60,
      "memory": 512,
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/api/index.js"
    }
  ]
}
