{
  "version": 2,
  "buildCommand": "npm install && cd backend && npm install",
  "outputDirectory": "pages",
  "functions": {
    "backend/api/index.js": {
      "maxDuration": 60,
      "memory": 512,
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
